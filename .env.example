# ─────────────────────────────────────────────────────────────────
# EthioCode — Environment Variables
# Copy this file to .env and fill in every value before running.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_DB=ethiocode
POSTGRES_USER=ethiocode_user
POSTGRES_PASSWORD=your_strong_password_here

# Built from the values above — update if you change host/port
DATABASE_URL=postgresql://ethiocode_user:your_strong_password_here@postgres:5432/ethiocode

# ── Backend ───────────────────────────────────────────────────────
PORT=3001

# At least 32 random characters — used to sign JWTs
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_min_32_chars_replace_this

# Password you will use to log into the /admin.html dashboard
ADMIN_PASSWORD=your_admin_password_here

# ── Frontend / Nginx ──────────────────────────────────────────────
# Port the nginx container exposes to the host (default 80)
FRONTEND_PORT=80
