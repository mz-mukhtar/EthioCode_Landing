# PostgreSQL
POSTGRES_DB=ethiocode
POSTGRES_USER=ethiocode_user
POSTGRES_PASSWORD=change_me

# Backend DB connection (uses service name 'postgres' as hostname inside Docker)
DATABASE_URL=postgresql://ethiocode_user:change_me@postgres:5432/ethiocode

# Backend
PORT=3001
JWT_SECRET=change_me_use_at_least_32_random_characters_here
ADMIN_PASSWORD=change_me
